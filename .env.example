# ──────────────────────────────────────────────
# TriLiska POS Gateway — Environment Variables
# ──────────────────────────────────────────────

# Application
APP_PORT=3000
NODE_ENV=development

# Database (Postgres 16)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=trilaska_gateway
DATABASE_USER=trilaska
DATABASE_PASSWORD=trilaska_dev_password

# JWT (RS256)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ERP Adapter
ERP_MODE=mock
ERPNEXT_BASE_URL=http://localhost:8000
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Mock Adapter Settings
MOCK_FAILURE_RATE=0.0
MOCK_FAILURE_TYPE=5xx
MOCK_FORWARD_DELAY_MS=100

# Rate Limiting
RATE_LIMIT_DEVICE_RPM=10
RATE_LIMIT_MSME_SYNC_RPH=30
RATE_LIMIT_LOGIN_PER_PHONE=5
RATE_LIMIT_LOGIN_PER_IP=20

# Sync Worker
SYNC_WORKER_POLL_INTERVAL_MS=1000
SYNC_WORKER_RETRY_BASE_MS=2000
SYNC_WORKER_RETRY_MAX_MS=32000
SYNC_WORKER_RETRY_JITTER_MS=500

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=30000
